   "source": [
    "import pandas as pd\n",
    "import matplotlib.pyplot as plt\n",
    "\n",
    "data = {\n",
    "    \"Month\": [\"Jan\",\"Feb\",\"Mar\",\"Apr\",\"May\"],\n",
    "    \"Sales\": [20000,25000,30000,28000,35000]\n",
    "}\n",
    "\n",
    "df = pd.DataFrame(data)\n",
    "\n",
    "df.plot(x=\"Month\", y=\"Sales\", kind=\"line\")\n",
    "plt.title(\"Sales Trend\")\n",
    "plt.show()"
   ]
